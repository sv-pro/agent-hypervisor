# Agent Hypervisor Browser Demo — environment variable overrides
# Copy to .env and edit as needed.

# Service bind address (keep 127.0.0.1 for local-only access)
AH_HOST=127.0.0.1

# Service port (default: 17841 — avoids common occupied ports like 7777/8080)
AH_PORT=17841

# Session token sent in X-Session-Token header by the extension
# Change this to any non-guessable string before sharing a demo environment
AH_SESSION_TOKEN=demo-local-token

# Where the service writes its bootstrap.json on startup
# AH_BOOTSTRAP_PATH=~/.agent-hypervisor/bootstrap.json

# Trace and memory store paths (relative to where you run the service)
# AH_TRACE_STORE_PATH=./data/traces.jsonl
# AH_MEMORY_STORE_PATH=./data/memory.json
